{
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@site/*": ["./*"]
    },
    "types": [
      "node",
      "@docusaurus/module-type-aliases",
      "@docusaurus/theme-classic"
    ]
  },
  "include": [
    "dls/scss.d.ts",
    "src/pages/**/*.ts",
    "src/pages/**/*.tsx",
    "src/components/**/*.ts",
    "src/components/**/*.tsx",
    "src/**/*.d.ts"
  ]
}
